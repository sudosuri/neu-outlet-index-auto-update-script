# Neu Appliance — filter index auto-update config
#
# LOCAL runs:  copy this file to ".env" (same folder) and paste your real values. ".env" is gitignored.
# GitHub Actions:  set these as repository SECRETS instead (Settings > Secrets and variables > Actions).
#                  Never commit real token values.

NEU_SHOPIFY_STORE=neu-appliances-2021.myshopify.com
NEU_SHOPIFY_API_VERSION=2025-01

# Admin API access token — the token MUST have both:  read_products  AND  write_themes
NEU_SHOPIFY_ACCESS_TOKEN=paste_your_admin_token_here_or_set_in_env

# The LIVE theme id the fresh index is deployed to (used by deploy-index.mjs):
NEU_THEME_ID=156331507885
